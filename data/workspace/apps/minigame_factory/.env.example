# Database (currently optional; API v1.1 doesn't require DB operations)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=minigame
DATABASE_URL=postgresql+psycopg://app:app@db:5432/minigame

# Redis (RQ)
REDIS_URL=redis://redis:6379/0

# Android signing (for release AAB; optional)
KEYSTORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=
