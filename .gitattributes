# GitHub Actions workflow files — force LF (yamllint requires \n, not \r\n)
.github/workflows/*.yml text eol=lf
.github/workflows/*.yaml text eol=lf

# General YAML/Python — LF
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Windows batch files — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
