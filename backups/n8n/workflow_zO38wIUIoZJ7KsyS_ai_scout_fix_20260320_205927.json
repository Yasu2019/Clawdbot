    {
      "id": "node-aggregate",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        40
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst allItems = $input.all();\nconst seen = new Set();\nconst results = [];\n\nfor (const item of allItems) {\n  const data = item.json;\n  const hits = data.results || [];\n  for (const r of hits.slice(0, 3)) {\n    const key = r.url || r.title;\n    if (!seen.has(key) && r.title) {\n      seen.add(key);\n      results.push(`- ${r.title}\\n  ${r.url || ''}`);\n    }\n  }\n}\n\nreturn [{ json: { summary_input: results.slice(0, 20).join('\\n') } }];\n"
      }
    },
    {
      "id": "node-llm",
      "name": "Gemini Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        40
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/generate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "body": "={{ JSON.stringify({ model: 'qwen2.5-coder:7b', prompt: 'あなたはAI業界ウォッチャーです。与えられた検索結果から、AIモデル、動画生成、音楽生成、画像生成、リップシンク、DeepLearning、業務活用の観点で本当に新しい情報だけを日本語で5-10件の箇条書きに整理してください。各項目は短く、媒体名や人物名が分かる場合は含めてください。SNSや動画は検索結果に含まれる公開ページだけを根拠にし、未確認の断定は避けてください。検索結果:\\n' + $json.summary_input, stream: false, options: { num_predict: 700, temperature: 0.2 } }) }}"
      }
    },
    {
      "id": "node-extract",
      "name": "Extract AI Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        40
      ],
      "parameters": {
        "jsCode": "const body = $input.item.json || {};\nconst content = (body.response || '').trim() || '(結果なし)';\nconst today = new Date().toLocaleDateString('ja-JP', { timeZone: 'Asia/Tokyo' });\nreturn [{\n  json: {\n    message: `AI Scout 日報 (${today})\\n\\n${content}\\n\\n---\\n取得元: SearXNG 公開Web検索`\n  }\n}];"
      }
    },
    {
