<%# ===== 固定ヘッダー ===== %>
<div class="sticky top-0 bg-base-100 border-b border-base-300 z-20 shadow-sm">
  <div class="container mx-auto px-4 py-2">
    <div class="flex flex-wrap items-center gap-3">

      <%# ユーザー情報 %>
      <div class="text-xs text-base-content/70 flex gap-3">
        <span><strong><%= @user.name %></strong></span>
        <span class="badge badge-outline badge-xs"><%= @user.role %></span>
        <span class="hidden sm:inline"><%= @process_name %></span>
      </div>

      <%# テスト開始フォーム %>
      <div class="flex items-center gap-2 ml-auto">
        <%= form_with(url: new_touan_path, method: :get, local: true, class: "flex items-center gap-2") do |form| %>
          <% @tes = Testmondai.select(:kajyou).distinct.order(:kajyou) %>
          <%= form.collection_select(:kajyou, @tes, :kajyou, :kajyou, { prompt: '箇条を選択' },
                class: "select select-sm select-bordered max-w-xs") %>
          <%= form.submit "テスト開始", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>

      <%# スタッフ用メニュー %>
      <div class="<%= @user.role == 'staff' ? 'flex' : 'hidden' %> items-center gap-2 flex-wrap">
        <%= link_to "Excel出力", xlsx_touan_path(@touan, format: :xlsx), class: "btn btn-outline btn-sm" %>

        <%= form_tag import_kaitou_touans_path, multipart: true, class: "flex items-center gap-1" do %>
          <%= file_field_tag :file, class: "file-input file-input-bordered file-input-sm w-44" %>
          <%= submit_tag "インポート", class: "btn btn-outline btn-sm" %>
        <% end %>

        <%= form_with(url: testmondai_touan_path, method: :get, local: true) do |form| %>
          <%= form.submit "問題一覧", class: "btn btn-outline btn-sm" %>
        <% end %>

        <%= form_with(url: member_current_status_touan_path, method: :get, local: true) do |form| %>
          <%= form.submit "進捗一覧", class: "btn btn-outline btn-sm" %>
        <% end %>
      </div>

    </div>
  </div>
</div>

<%# ===== タブナビゲーション ===== %>
<div class="tab-wrap">
  <input id="tab1" type="radio" name="tab_btn" checked>
  <input id="tab2" type="radio" name="tab_btn">
  <input id="tab3" type="radio" name="tab_btn">

  <div class="tab-labels">
    <label for="tab1">テスト結果</label>
    <label for="tab2"><%= @owner_select_jp %>が主管の箇条</label>
    <label for="tab3"><%= @owner_select_jp %>が関係する箇条</label>
  </div>

  <div class="tab-panels">

    <%# ===== Panel 1: テスト結果 ===== %>
    <div id="panel1" class="tab-panel">
      <div class="container mx-auto px-4 py-6">
        <div class="flex flex-col gap-6">

          <%# レーダーチャート (全幅) %>
          <div class="w-full">
            <% chart_kajyou = [] %>
            <% chart_average_score = [] %>
            <% @tes = Testmondai.select(:kajyou).distinct.order(:kajyou) %>
            <% @tes.each do |t| %>
              <% next unless t.kajyou %>
              <% chart_kajyou.push(t.kajyou) %>
              <% only_kajyou = @touans.where(kajyou: t.kajyou) %>
              <% correct_count = only_kajyou.select { |ave| ave.seikai == ave.kaito }.count %>
              <% total_count = only_kajyou.count %>
              <% chart_average_score.push(total_count > 0 ? (correct_count.to_f / total_count * 100) : 0.0) %>
            <% end %>

            <div class="card bg-base-100 shadow-md">
              <div class="card-body p-4">
                <h3 class="card-title text-sm font-semibold text-base-content/70 mb-2">評価結果レーダーチャート</h3>
                <div class="w-full" style="height: 750px; position: relative;">
                  <canvas id="chartRadar"></canvas>
                </div>
              </div>
            </div>
          </div>

          <%# テスト履歴テーブル %>
          <div class="w-full">
            <div class="card bg-base-100 shadow-md">
              <div class="card-body p-4">
                <h3 class="card-title text-sm font-semibold text-base-content/70 mb-3">テスト履歴</h3>
                <% @touan_dates = @touans.select("DISTINCT date_trunc('minute', created_at) as created_at").order("created_at") %>
                <div class="overflow-x-auto">
                  <table class="table table-sm table-zebra w-full">
                    <thead>
                      <tr>
                        <th>箇条</th>
                        <th>実施日</th>
                        <th>正解率</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <%
                        @touan_dates.each do |da|
                          data = { correct_count: 0, total_count: 0, related_touans: [], kajyou: nil, test_created_at: nil }
                          @touans.each do |test|
                            if ((da.created_at - 1.minute)..(da.created_at + 1.minute)).cover?(test.created_at)
                              data[:correct_count] += 1 if test.seikai == test.kaito
                              data[:total_count]   += 1
                              data[:kajyou]          = test.kajyou
                              data[:test_created_at] = test.created_at
                              data[:related_touans] << test
                            end
                          end
                      %>
                        <tr>
                          <td class="font-medium"><%= data[:kajyou] %></td>
                          <td class="text-xs"><%= data[:test_created_at]&.strftime("%m/%d %H:%M") %></td>
                          <td>
                            <% pct = data[:total_count] > 0 ? sprintf("%.0f", data[:correct_count].to_f / data[:total_count] * 100) : '0' %>
                            <span class="badge badge-sm <%= pct.to_i >= 80 ? 'badge-success' : pct.to_i >= 60 ? 'badge-warning' : 'badge-error' %>">
                              <%= pct %>%
                            </span>
                          </td>
                          <td class="flex gap-1">
                            <% if data[:related_touans].any? %>
                              <%= form_with(url: kekka_touan_path, method: :get, local: true) do |form| %>
                                <%= form.hidden_field :created_at, value: data[:test_created_at] %>
                                <%= form.submit "結果", class: "btn btn-xs btn-primary" %>
                              <% end %>
                              <%= button_to '削除', delete_related_touans_path(target_date: data[:test_created_at]),
                                    method: :delete,
                                    data: { confirm: '本当に削除しますか？' },
                                    class: 'btn btn-xs btn-ghost text-error' %>
                            <% end %>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <%# ===== Panel 2: 主管箇条 ===== %>
    <div id="panel2" class="tab-panel">
      <div class="container mx-auto px-4 py-6">
        <% chart_kajyou_audit, chart_score_audit = calculate_chart_data(@iatf_data_audit, @touans) %>
        <div class="flex flex-col gap-6">
          <div class="card bg-base-100 shadow-md">
            <div class="card-body p-4">
              <h3 class="card-title text-sm font-semibold text-base-content/70 mb-2">評価結果レーダーチャート</h3>
              <div class="w-full" style="height: 750px; position: relative;">
                <canvas id="chartRadar_iatf_request_audit"></canvas>
              </div>
            </div>
          </div>
          <%= link_to '← 戻る', root_path, class: 'btn btn-ghost btn-sm' %>
          <%= render partial: "table", locals: {
              headers:   ["箇条", "タイトル", "平均得点", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              items:     @iatf_data_audit,
              columns:   [:no, :name, "average_score", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              products:  @products,
              iatflists: @iatflists,
              csrs:      @csrs,
              touans:    @touans } %>
        </div>
      </div>
    </div>

    <%# ===== Panel 3: 関係箇条 ===== %>
    <div id="panel3" class="tab-panel">
      <div class="container mx-auto px-4 py-6">
        <% chart_kajyou_audit_sub, chart_score_audit_sub = calculate_chart_data(@iatf_data_audit_sub, @touans) %>
        <div class="flex flex-col gap-6">
          <div class="card bg-base-100 shadow-md">
            <div class="card-body p-4">
              <h3 class="card-title text-sm font-semibold text-base-content/70 mb-2">評価結果レーダーチャート</h3>
              <div class="w-full" style="height: 750px; position: relative;">
                <canvas id="chartRadar_iatf_request_audit_sub"></canvas>
              </div>
            </div>
          </div>
          <%= link_to '← 戻る', root_path, class: 'btn btn-ghost btn-sm' %>
          <%= render partial: "table", locals: {
              headers:   ["箇条", "タイトル", "平均得点", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              items:     @iatf_data_audit_sub,
              columns:   [:no, :name, "average_score", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              products:  @products,
              iatflists: @iatflists,
              csrs:      @csrs,
              touans:    @touans } %>
        </div>
      </div>
    </div>

  </div><%# /tab-panels %>
</div><%# /tab-wrap %>

<div class="container mx-auto px-4 py-2">
  <%= link_to '← 戻る', root_path, class: 'btn btn-ghost btn-sm' %>
</div>


<%# ===== タブCSS ===== %>
<style>
.tab-wrap { width: 100%; }
.tab-wrap > input[type="radio"] { display: none; }

.tab-labels {
  display: flex;
  gap: 0.25rem;
  padding: 0.75rem 1rem 0;
  background: oklch(var(--b2));
  border-bottom: 2px solid oklch(var(--b3));
}
.tab-labels label {
  padding: 0.5rem 1.25rem;
  border-radius: 0.5rem 0.5rem 0 0;
  cursor: pointer;
  font-size: 0.875rem;
  font-weight: 500;
  color: oklch(var(--bc) / 0.5);
  background: oklch(var(--b3));
  transition: all 0.15s ease;
  border: 1px solid oklch(var(--b3));
  border-bottom: none;
  margin-bottom: -2px;
}
.tab-labels label:hover { color: oklch(var(--bc) / 0.8); }

#tab1:checked ~ .tab-labels label[for="tab1"],
#tab2:checked ~ .tab-labels label[for="tab2"],
#tab3:checked ~ .tab-labels label[for="tab3"] {
  background: oklch(var(--b1));
  color: oklch(var(--p));
  font-weight: 600;
  border-color: oklch(var(--b3));
  border-bottom-color: oklch(var(--b1));
}

.tab-panels { background: oklch(var(--b1)); }
.tab-panel   { display: none; }

#tab1:checked ~ .tab-panels #panel1 { display: block; }
#tab2:checked ~ .tab-panels #panel2 { display: block; }
#tab3:checked ~ .tab-panels #panel3 { display: block; }
</style>


<%# ===== Chart.js ===== %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1"></script>

<script>
function createRadarChart(elementId, labels, data) {
  const el = document.getElementById(elementId);
  if (!el) return;
  if (window[elementId] instanceof Chart) {
    window[elementId].destroy();
  }
  window[elementId] = new Chart(el, {
    type: "radar",
    data: {
      labels: labels,
      datasets: [{
        label: "テスト正解率(%)",
        data: data,
        fill: true,
        backgroundColor: "rgba(133, 105, 241, 0.15)",
        borderColor: "rgb(133, 105, 241)",
        pointBackgroundColor: "rgb(133, 105, 241)",
        pointBorderColor: "#fff",
        pointHoverBackgroundColor: "#fff",
        pointHoverBorderColor: "rgb(133, 105, 241)"
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        r: {
          min: 0, max: 100, stepSize: 20,
          ticks:       { font: { size: 16 }, backdropPadding: 4 },
          pointLabels: { font: { size: 16, weight: 'bold' } }
        }
      },
      plugins: {
        legend:  { labels:    { font: { size: 18 }, padding: 20 } },
        tooltip: { bodyFont:  { size: 16 }, titleFont: { size: 16 } }
      }
    }
  });
}

document.addEventListener("turbo:load", function() {
  createRadarChart("chartRadar", <%= raw chart_kajyou.to_json %>, <%= chart_average_score.map(&:to_f).to_json %>);
  createRadarChart("chartRadar_iatf_request_audit",     <%= raw chart_kajyou_audit.to_json %>,     <%= chart_score_audit.map(&:to_f).to_json %>);
  createRadarChart("chartRadar_iatf_request_audit_sub", <%= raw chart_kajyou_audit_sub.to_json %>, <%= chart_score_audit_sub.map(&:to_f).to_json %>);
});

document.addEventListener("turbo:before-cache", function() {
  ["chartRadar", "chartRadar_iatf_request_audit", "chartRadar_iatf_request_audit_sub"].forEach(function(id) {
    if (window[id] instanceof Chart) { window[id].destroy(); window[id] = null; }
  });
});
</script>
