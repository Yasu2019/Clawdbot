<%# ===== 固定ヘッダー ===== %>
<div class="sticky top-0 bg-base-100 border-b border-base-300 z-20 shadow-sm">
  <div class="container mx-auto px-4 py-2">
    <div class="flex flex-wrap items-center gap-3">

      <%# ユーザー情報 %>
      <div class="text-xs text-base-content/70 flex gap-3">
        <span><strong><%= @user.name %></strong></span>
        <span class="badge badge-outline badge-xs"><%= @user.role %></span>
        <span class="hidden sm:inline"><%= @process_name %></span>
      </div>

      <%# テスト開始フォーム %>
      <div class="flex items-center gap-2 ml-auto">
        <%= form_with(url: new_touan_path, method: :get, local: true, class: "flex items-center gap-2") do |form| %>
          <% @tes = Testmondai.select(:kajyou).distinct.order(:kajyou) %>
          <%= form.collection_select(:kajyou, @tes, :kajyou, :kajyou, { prompt: '箇条を選択' },
                class: "select select-sm select-bordered max-w-xs", required: true) %>
          <%= form.submit "テスト開始", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>

      <%# スタッフ用メニュー %>
      <div class="<%= @user.role == 'staff' ? 'flex' : 'hidden' %> items-center gap-2 flex-wrap">
        <%= link_to "Excel出力", xlsx_touan_path(@touan, format: :xlsx), class: "btn btn-outline btn-sm" %>

        <%= form_tag import_kaitou_touans_path, multipart: true, class: "flex items-center gap-1" do %>
          <%= file_field_tag :file, class: "file-input file-input-bordered file-input-sm w-44" %>
          <%= submit_tag "インポート", class: "btn btn-outline btn-sm" %>
        <% end %>

        <%= form_with(url: testmondai_touan_path, method: :get, local: true) do |form| %>
          <%= form.submit "問題一覧", class: "btn btn-outline btn-sm" %>
        <% end %>

        <%= form_with(url: member_current_status_touan_path, method: :get, local: true) do |form| %>
          <%= form.submit "進捗一覧", class: "btn btn-outline btn-sm" %>
        <% end %>
      </div>

    </div>
  </div>
</div>

<%# ===== タブナビゲーション ===== %>
<div class="tab-wrap">
  <input id="tab1" type="radio" name="tab_btn" checked>
  <input id="tab2" type="radio" name="tab_btn">
  <input id="tab3" type="radio" name="tab_btn">

  <div class="tab-labels">
    <label for="tab1">📊 テスト結果</label>
    <label for="tab2" class="tab-label-shuukan">⭐ 主管箇条</label>
    <label for="tab3" class="tab-label-kankei">🔗 関係箇条</label>
  </div>

  <div class="tab-panels">

    <%# ===== Panel 1: テスト結果 ===== %>
    <div id="panel1" class="tab-panel">
      <div class="container mx-auto px-4 py-6">
        <div class="flex flex-col gap-6">

          <%# レーダーチャート (全幅) %>
          <div class="w-full">
            <% chart_kajyou = [] %>
            <% chart_average_score = [] %>
            <% @tes = Testmondai.select(:kajyou).distinct.order(:kajyou) %>
            <% @tes.each do |t| %>
              <% next unless t.kajyou %>
              <% chart_kajyou.push(t.kajyou) %>
              <% only_kajyou = @touans.where(kajyou: t.kajyou) %>
              <% correct_count = only_kajyou.select { |ave| ave.seikai == ave.kaito }.count %>
              <% total_count = only_kajyou.count %>
              <% chart_average_score.push(total_count > 0 ? (correct_count.to_f / total_count * 100) : 0.0) %>
            <% end %>

            <div class="card bg-base-100 shadow-md">
              <div class="card-body p-4">
                <h3 class="card-title text-sm font-semibold text-base-content/70 mb-2">評価結果レーダーチャート</h3>
                <div class="w-full" style="height: 750px; position: relative;">
                  <canvas id="chartRadar"></canvas>
                </div>
              </div>
            </div>
          </div>

          <%# テスト履歴テーブル %>
          <div class="w-full">
            <div class="card bg-base-100 shadow-md">
              <div class="card-body p-4">
                <h3 class="card-title text-sm font-semibold text-base-content/70 mb-3">テスト履歴</h3>
                <% @touan_dates = @touans.select("DISTINCT date_trunc('minute', created_at) as created_at").order("created_at") %>
                <div class="overflow-x-auto">
                  <table class="table table-sm table-zebra w-full">
                    <thead>
                      <tr>
                        <th>箇条</th>
                        <th>実施日</th>
                        <th>正解率</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <%
                        @touan_dates.each do |da|
                          data = { correct_count: 0, total_count: 0, related_touans: [], kajyou: nil, test_created_at: nil }
                          @touans.each do |test|
                            if ((da.created_at - 1.minute)..(da.created_at + 1.minute)).cover?(test.created_at)
                              data[:correct_count] += 1 if test.seikai == test.kaito
                              data[:total_count]   += 1
                              data[:kajyou]          = test.kajyou
                              data[:test_created_at] = test.created_at
                              data[:related_touans] << test
                            end
                          end
                      %>
                        <tr>
                          <td class="font-medium"><%= data[:kajyou] %></td>
                          <td class="text-xs"><%= data[:test_created_at]&.strftime("%m/%d %H:%M") %></td>
                          <td>
                            <% pct = data[:total_count] > 0 ? sprintf("%.0f", data[:correct_count].to_f / data[:total_count] * 100) : '0' %>
                            <span class="badge badge-lg text-lg font-bold px-3 py-4 <%= pct.to_i >= 80 ? 'badge-success' : pct.to_i >= 60 ? 'badge-warning' : 'badge-error' %>">
                              <%= pct %>%
                            </span>
                          </td>
                          <td>
                            <% if data[:related_touans].any? %>
                              <div class="flex flex-col gap-1">
                                <%= form_with(url: kekka_touan_path, method: :get, local: true) do |form| %>
                                  <%= form.hidden_field :created_at, value: data[:test_created_at] %>
                                  <%= form.submit "📋 テスト結果の詳細解説", class: "btn btn-sm btn-primary w-full" %>
                                <% end %>
                                <%= button_to '削除', delete_related_touans_path(target_date: data[:test_created_at]),
                                      method: :delete,
                                      data: { confirm: '本当に削除しますか？' },
                                      class: 'btn btn-xs btn-ghost text-error w-full' %>
                              </div>
                            <% end %>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <%# ===== Panel 2: 主管箇条 ===== %>
    <div id="panel2" class="tab-panel">
      <div class="container mx-auto px-4 py-6">
        <% chart_kajyou_audit, chart_score_audit = calculate_chart_data(@iatf_data_audit, @touans) %>
        <div class="flex flex-col gap-6">
          <%# 主管バナー %>
          <div class="rounded-xl px-4 py-3 flex items-center gap-3" style="background:#fef9c3; border:2px solid #f59e0b;">
            <span style="font-size:1.5rem;">⭐</span>
            <div>
              <p class="font-bold text-base" style="color:#92400e;"><%= @owner_select_jp %> が<span class="underline decoration-amber-500">主管</span>する箇条</p>
              <p class="text-xs" style="color:#b45309;">このプロセスが責任者として直接管理・運営する要求事項です。</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md" style="border:2px solid #f59e0b;">
            <div class="card-body p-4">
              <h3 class="card-title text-sm font-semibold mb-2" style="color:#b45309;">⭐ 主管箇条 — 評価結果レーダーチャート</h3>
              <div class="w-full" style="height: 750px; position: relative;">
                <canvas id="chartRadar_iatf_request_audit"></canvas>
              </div>
            </div>
          </div>
          <%= link_to '← 戻る', root_path, class: 'btn btn-ghost btn-sm' %>
          <%= render partial: "table", locals: {
              headers:   ["箇条", "タイトル", "平均得点", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              items:     @iatf_data_audit,
              columns:   [:no, :name, "average_score", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              products:  @products,
              iatflists: @iatflists,
              csrs:      @csrs,
              touans:    @touans } %>
        </div>
      </div>
    </div>

    <%# ===== Panel 3: 関係箇条 ===== %>
    <div id="panel3" class="tab-panel">
      <div class="container mx-auto px-4 py-6">
        <% chart_kajyou_audit_sub, chart_score_audit_sub = calculate_chart_data(@iatf_data_audit_sub, @touans) %>
        <div class="flex flex-col gap-6">
          <%# 関係バナー %>
          <div class="rounded-xl px-4 py-3 flex items-center gap-3" style="background:#ccfbf1; border:2px solid #14b8a6;">
            <span style="font-size:1.5rem;">🔗</span>
            <div>
              <p class="font-bold text-base" style="color:#134e4a;"><%= @owner_select_jp %> が<span class="underline decoration-teal-500">関係</span>する箇条</p>
              <p class="text-xs" style="color:#0f766e;">他プロセスが主管するが、このプロセスも連携・協力が必要な要求事項です。</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md" style="border:2px solid #14b8a6;">
            <div class="card-body p-4">
              <h3 class="card-title text-sm font-semibold mb-2" style="color:#0f766e;">🔗 関係箇条 — 評価結果レーダーチャート</h3>
              <div class="w-full" style="height: 750px; position: relative;">
                <canvas id="chartRadar_iatf_request_audit_sub"></canvas>
              </div>
            </div>
          </div>
          <%= link_to '← 戻る', root_path, class: 'btn btn-ghost btn-sm' %>
          <%= render partial: "table", locals: {
              headers:   ["箇条", "タイトル", "平均得点", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              items:     @iatf_data_audit_sub,
              columns:   [:no, :name, "average_score", "IATF要求事項", "MEK様品質ガイドラインVer2", "添付ファイル"],
              products:  @products,
              iatflists: @iatflists,
              csrs:      @csrs,
              touans:    @touans } %>
        </div>
      </div>
    </div>

  </div><%# /tab-panels %>
</div><%# /tab-wrap %>

<div class="container mx-auto px-4 py-2">
  <%= link_to '← 戻る', root_path, class: 'btn btn-ghost btn-sm' %>
</div>


<%# ===== タブCSS ===== %>
<style>
.tab-wrap { width: 100%; }
.tab-wrap > input[type="radio"] { display: none; }

.tab-labels {
  display: flex;
  gap: 0.25rem;
  padding: 0.75rem 1rem 0;
  background: oklch(var(--b2));
  border-bottom: 2px solid oklch(var(--b3));
}
.tab-labels label {
  padding: 0.75rem 2rem;
  border-radius: 0.5rem 0.5rem 0 0;
  cursor: pointer;
  font-size: 1.05rem;
  font-weight: 500;
  color: oklch(var(--bc) / 0.5);
  background: oklch(var(--b3));
  transition: all 0.15s ease;
  border: 1px solid oklch(var(--b3));
  border-bottom: none;
  margin-bottom: -2px;
}
.tab-labels label:hover { color: oklch(var(--bc) / 0.8); }

#tab1:checked ~ .tab-labels label[for="tab1"] {
  background: oklch(var(--b1));
  color: oklch(var(--p));
  font-weight: 600;
  border-color: oklch(var(--b3));
  border-bottom-color: oklch(var(--b1));
}

/* 主管タブ：金色系 */
.tab-label-shuukan { color: #92400e !important; }
#tab2:checked ~ .tab-labels label[for="tab2"] {
  background: #fef9c3;
  color: #78350f;
  font-weight: 700;
  border-color: #f59e0b;
  border-bottom-color: #fef9c3;
  font-size: 1.1rem;
}

/* 関係タブ：青緑系 */
.tab-label-kankei { color: #0f766e !important; }
#tab3:checked ~ .tab-labels label[for="tab3"] {
  background: #ccfbf1;
  color: #134e4a;
  font-weight: 700;
  border-color: #14b8a6;
  border-bottom-color: #ccfbf1;
  font-size: 1.1rem;
}

.tab-panels { background: oklch(var(--b1)); }
.tab-panel   { display: none; }

#tab1:checked ~ .tab-panels #panel1 { display: block; }
#tab2:checked ~ .tab-panels #panel2 { display: block; }
#tab3:checked ~ .tab-panels #panel3 { display: block; }
</style>


<%# ===== Chart.js (Chart.bundle 4.4.1 via importmap — CDN script 不要) ===== %>
<script>
// チャートデータ（ERBでサーバーサイドレンダリング）
var CHART_DATA = {
  all:   { labels: <%= raw chart_kajyou.to_json %>,           scores: <%= chart_average_score.map(&:to_f).to_json %>,           color: "rgb(133,105,241)", label: "テスト正解率(%)" },
  main:  { labels: <%= raw chart_kajyou_audit.to_json %>,      scores: <%= chart_score_audit.map(&:to_f).to_json %>,      color: "rgb(245,158,11)",  label: "⭐ 主管箇条 正解率(%)" },
  sub:   { labels: <%= raw chart_kajyou_audit_sub.to_json %>,  scores: <%= chart_score_audit_sub.map(&:to_f).to_json %>,  color: "rgb(20,184,166)",   label: "🔗 関係箇条 正解率(%)" }
};

var CHART_MAP = {
  "chartRadar":                        CHART_DATA.all,
  "chartRadar_iatf_request_audit":     CHART_DATA.main,
  "chartRadar_iatf_request_audit_sub": CHART_DATA.sub
};

// ── プラグイン登録フラグ ──
// renderChart() 内で初回だけ Chart.register() を呼ぶ。
// こうすることで Chart.bundle 4.4.1 が window.Chart に設定された後に
// 確実に同じインスタンスへ登録できる（CDN版と混在しない）。
var _radarColorPluginRegistered = false;

function ensureRadarColorPlugin() {
  if (_radarColorPluginRegistered) return;
  if (typeof Chart === 'undefined') return;

  Chart.register({
    id: 'radarAxisColor',
    afterDraw: function(chart) {
      if (chart.config.type !== 'radar') return;
      var scale = chart.scales && chart.scales.r;
      if (!scale || !scale._pointLabelItems || !scale._pointLabelItems.length) return;
      if (!scale._pointLabels || !scale._pointLabels.length) return;

      var ds = chart.data.datasets[0];
      if (!ds) return;
      var color = ds.borderColor;

      var ctx    = chart.ctx;
      var labels = scale._pointLabels;
      var items  = scale._pointLabelItems;
      var plOpts = scale.options.pointLabels;
      var fontSize   = (plOpts.font && plOpts.font.size)   || 14;
      var fontWeight = (plOpts.font && plOpts.font.weight) || 'bold';
      var fontFamily = (plOpts.font && plOpts.font.family) ||
                       (Chart.defaults.font && Chart.defaults.font.family) || 'sans-serif';
      var lineHeight = fontSize * 1.2;

      ctx.save();
      ctx.font         = fontWeight + ' ' + fontSize + 'px ' + fontFamily;
      ctx.textBaseline = 'middle';
      ctx.fillStyle    = color;

      items.forEach(function(item, i) {
        if (!item.visible) return;
        var rawLabel = labels[i];
        if (rawLabel === undefined || rawLabel === null) return;
        var lines = Array.isArray(rawLabel) ? rawLabel : [String(rawLabel)];
        ctx.textAlign = item.textAlign || 'center';
        // Chart.bundle.js drawPointLabels と同じ座標:
        //   renderText(ctx, label, item.x, item.y + lineHeight/2, ...)
        lines.forEach(function(line, j) {
          ctx.fillText(String(line), item.x, item.y + lineHeight / 2 + j * lineHeight);
        });
      });

      ctx.restore();
    }
  });

  _radarColorPluginRegistered = true;
}

function renderChart(elementId) {
  var el = document.getElementById(elementId);
  if (!el) return;

  // Chart.bundle 4.4.1 インスタンスへプラグイン登録（初回のみ）
  ensureRadarColorPlugin();

  if (typeof Chart !== 'undefined' && window[elementId] instanceof Chart) {
    window[elementId].destroy();
  }
  var d = CHART_MAP[elementId];
  if (!d || d.labels.length === 0) return;
  if (typeof Chart === 'undefined') return;

  var bg = d.color.replace("rgb(", "rgba(").replace(")", ", 0.18)");
  window[elementId] = new Chart(el, {
    type: "radar",
    data: {
      labels: d.labels,
      datasets: [{
        label: d.label, data: d.scores, fill: true,
        backgroundColor: bg, borderColor: d.color,
        pointBackgroundColor: d.color, pointBorderColor: "#fff",
        pointHoverBackgroundColor: "#fff", pointHoverBorderColor: d.color
      }]
    },
    options: {
      animation: false,
      responsive: true, maintainAspectRatio: false,
      scales: {
        r: {
          min: 0, max: 100,
          ticks:       { stepSize: 20, font: { size: 13 }, color: d.color, backdropColor: "transparent" },
          pointLabels: { font: { size: 14, weight: "bold" }, color: "rgba(0,0,0,0)" },
          grid:        { color: "rgba(0,0,0,0.1)" },
          angleLines:  { color: "rgba(0,0,0,0.15)" }
        }
      },
      plugins: {
        legend:  { labels: { font: { size: 15 }, padding: 20, color: d.color } },
        tooltip: { bodyFont: { size: 13 }, titleFont: { size: 13 } }
      }
    }
  });
}

// ページ読み込み時: Panel1（可視）のみ生成
function initChart1() { renderChart("chartRadar"); }
document.addEventListener("turbo:load",       initChart1);
document.addEventListener("DOMContentLoaded", initChart1);

// タブ切り替え時: そのタブのチャートを生成（表示後に生成することでcanvasサイズが正確）
document.addEventListener("change", function(e) {
  if (e.target.name !== "tab_btn") return;
  var tabChartMap = { tab1: "chartRadar", tab2: "chartRadar_iatf_request_audit", tab3: "chartRadar_iatf_request_audit_sub" };
  var chartId = tabChartMap[e.target.id];
  if (chartId) { setTimeout(function() { renderChart(chartId); }, 30); }
});

document.addEventListener("turbo:before-cache", function() {
  Object.keys(CHART_MAP).forEach(function(id) {
    if (window[id] instanceof Chart) { window[id].destroy(); window[id] = null; }
  });
});
</script>
