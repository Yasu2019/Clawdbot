<%# ===== データ集計 (1パス) ===== %>
<% correct_count = 0 %>
<% total_count   = 0 %>
<% question_list = [] %>

<% @touans.group_by { |t| [t.user_id, t.created_at.change(usec: 0)] }.each do |(_, _), touans| %>
  <% total_count += touans.length %>
  <% touans.each_with_index do |touan, idx| %>
    <% is_correct = touan.seikai == touan.kaito %>
    <% correct_count += 1 if is_correct %>
    <% question_list << { touan: touan, is_correct: is_correct, num: idx + 1 } %>
  <% end %>
<% end %>

<div class="max-w-2xl mx-auto px-4 py-6">

  <%# ユーザー情報バー %>
  <div class="flex flex-wrap items-center gap-3 mb-5 p-3 bg-base-200 rounded-xl text-sm">
    <div><span class="font-semibold">名前：</span><%= @user.name %></div>
    <div><span class="font-semibold">識別：</span><%= @user.role %></div>
    <div class="ml-auto text-xs text-base-content/50"><%= @user.email %></div>
  </div>

  <%# スコアカード %>
  <% score_pct = total_count > 0 ? correct_count.to_f / total_count * 100 : 0.0 %>
  <% score_color = score_pct >= 80 ? 'bg-success text-success-content' : score_pct >= 60 ? 'bg-warning text-warning-content' : 'bg-error text-error-content' %>
  <div class="card <%= score_color %> shadow-xl mb-8">
    <div class="card-body items-center text-center py-6">
      <p class="text-lg font-semibold opacity-80 mb-1">テスト結果</p>
      <h2 class="text-5xl font-bold mb-2"><%= sprintf("%.1f", score_pct) %>%</h2>
      <p class="text-base opacity-80"><%= correct_count %> / <%= total_count %> 問正解</p>
    </div>
  </div>

  <%# 問題別結果 %>
  <% question_list.each do |q| %>
    <% touan = q[:touan] %>
    <% is_correct = q[:is_correct] %>

    <div class="card shadow-sm border mb-4 <%= is_correct ? 'border-success/40 bg-success/5' : 'border-error/40 bg-error/5' %>">
      <div class="card-body p-5">

        <%# ヘッダー行 %>
        <div class="flex items-center gap-2 mb-3">
          <span class="badge badge-primary badge-md font-bold">問題 <%= q[:num] %></span>
          <span class="badge badge-outline text-xs">箇条 <%= touan.kajyou %></span>
          <span class="ml-auto badge <%= is_correct ? 'badge-success' : 'badge-error' %> font-bold">
            <%= is_correct ? '✓ 正解' : '✗ 不正解' %>
          </span>
        </div>

        <%# 問題文 %>
        <p class="text-sm font-medium leading-relaxed mb-3"><%= touan.mondai %></p>

        <%# 選択肢 (正解・不正解を色分け) %>
        <div class="flex flex-col gap-1.5 mb-3">
          <% [['a', touan.mondai_a], ['b', touan.mondai_b], ['c', touan.mondai_c]].each do |val, text| %>
            <% is_seikai  = touan.seikai == val %>
            <% is_kaito   = touan.kaito  == val %>
            <% choice_class = if is_seikai
                                 'bg-success/20 border-success/60 text-success-content font-semibold'
                               elsif is_kaito && !is_seikai
                                 'bg-error/20 border-error/60 text-error-content'
                               else
                                 'border-base-200 opacity-50'
                               end %>
            <div class="flex items-start gap-2 px-3 py-2 rounded-lg border text-sm <%= choice_class %>">
              <span class="font-bold shrink-0 w-5"><%= val.upcase %>.</span>
              <span class="flex-1 leading-relaxed"><%= text.to_s.sub(/^選択肢[a-cA-C][：:]\s*/, '') %></span>
              <% if is_seikai %><span class="shrink-0 text-xs">← 正解</span><% end %>
              <% if is_kaito && !is_seikai %><span class="shrink-0 text-xs">← あなたの回答</span><% end %>
            </div>
          <% end %>
        </div>

        <%# 解説 %>
        <% if touan.kaisetsu.present? %>
          <div class="bg-base-200 rounded-lg p-3">
            <p class="text-xs font-semibold text-base-content/50 mb-1">解説</p>
            <p class="text-sm leading-relaxed"><%= touan.kaisetsu %></p>
          </div>
        <% end %>

      </div>
    </div>
  <% end %>

  <div class="mt-6 mb-8">
    <%= link_to '← 戻る', index_touan_path, class: 'btn btn-ghost btn-sm' %>
  </div>

</div>
