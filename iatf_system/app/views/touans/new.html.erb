<div class="max-w-2xl mx-auto px-4 py-6">

  <%# ユーザー情報バー %>
  <div class="flex flex-wrap items-center gap-3 mb-6 p-3 bg-base-200 rounded-xl text-sm">
    <div><span class="font-semibold">名前：</span><%= @user.name %></div>
    <div><span class="font-semibold">識別：</span><%= @user.role %></div>
    <div class="ml-auto text-xs text-base-content/50"><%= @user.email %></div>
  </div>

  <%= form_with model: @touans, url: touans_path, local: true do |form| %>

    <% i = 1 %>
    <% @touans.collection.each do |user| %>
      <%= fields_for 'touans[]', user, index: (i - 1) do |field| %>

        <%# 問題カード %>
        <div class="card bg-base-100 shadow-md border border-base-300 mb-6">
          <div class="card-body p-5">

            <%# 問題ヘッダー %>
            <div class="flex items-center gap-2 mb-3">
              <span class="badge badge-primary badge-lg font-bold px-3">問題 <%= i %></span>
              <span class="badge badge-outline text-xs">箇条 <%= user.kajyou %></span>
            </div>

            <%# 問題文 %>
            <p class="text-sm font-medium leading-relaxed mb-4 text-base-content"><%= user.mondai %></p>

            <%# 選択肢ラジオボタンカード %>
            <div class="flex flex-col gap-2" data-question="<%= i %>">
              <% [['a', user.mondai_a], ['b', user.mondai_b], ['c', user.mondai_c]].each do |val, choice_text| %>
                <div class="choice-wrapper">
                  <%= field.radio_button :kaito, val,
                        id:    "kaito_#{val}_#{i}",
                        class: "choice-radio",
                        style: "display:none;" %>
                  <label for="kaito_<%= val %>_<%= i %>" class="choice-label" data-letter="<%= val.upcase %>">
                    <span class="choice-badge">未選択</span>
                    <span class="choice-text"><%= choice_text.to_s.sub(/^選択肢[a-cA-C][：:]\s*/, '') %></span>
                  </label>
                </div>
              <% end %>
            </div>

            <%# 隠しフィールド群 %>
            <%= field.hidden_field :kajyou %>
            <%= field.hidden_field :mondai %>
            <%= field.hidden_field :mondai_a %>
            <%= field.hidden_field :mondai_b %>
            <%= field.hidden_field :mondai_c %>
            <%= field.hidden_field :seikai %>
            <%= field.hidden_field :kaisetsu %>
            <%= field.hidden_field :mondai_no %>
            <%= field.hidden_field :seikairitsu %>
            <%= field.hidden_field :total_answers %>
            <%= field.hidden_field :correct_answers %>
            <%= field.hidden_field :rev %>

          </div>
        </div>

        <% i += 1 %>
      <% end %>
    <% end %>

    <%# 送信ボタン (sticky) %>
    <div class="sticky bottom-4 z-10 flex flex-col items-center gap-1 mt-2 pb-2">
      <%= form.submit "提出する", class: "btn btn-primary btn-lg shadow-xl px-12", id: "submit-btn",
            disabled: true, style: "opacity:0.35; cursor:not-allowed;" %>
      <span id="submit-progress" class="text-xs text-base-content/50">0 / <%= @touans.collection.size %> 問回答済み</span>
    </div>

  <% end %>

  <div class="mt-4 mb-8">
    <%= link_to '← 戻る', touans_path, class: 'btn btn-ghost btn-sm' %>
  </div>

</div>

<%# 未回答警告 Toast (画面上部固定) %>
<div id="submit-warning"
     class="hidden fixed top-4 left-1/2 z-50 -translate-x-1/2 alert alert-warning shadow-xl text-sm px-5 py-3 rounded-xl max-w-lg w-11/12">
  <span id="submit-warning-text"></span>
</div>

<style>
/* 選択肢ラベル (未選択) */
.choice-label {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  border: 2px solid #d1d5db;
  cursor: pointer;
  transition: border-color 0.15s, background-color 0.15s, box-shadow 0.15s;
  user-select: none;
}
.choice-label:hover {
  border-color: #a5b4fc;
  background-color: #f5f3ff;
}

/* 選択肢バッジ (未選択 / A / B / C) */
.choice-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 3.5rem;
  height: 1.75rem;
  border-radius: 9999px;
  border: 2px solid #d1d5db;
  background-color: #f9fafb;
  color: #9ca3af;
  font-weight: 600;
  font-size: 0.7rem;
  flex-shrink: 0;
  transition: background-color 0.15s, color 0.15s, border-color 0.15s, min-width 0.15s;
  padding: 0 0.5rem;
}

.choice-text {
  font-size: 0.875rem;
  line-height: 1.6;
  padding-top: 0.2rem;
}

/* 未回答ハイライト */
.choice-label.is-unanswered {
  border-color: #f87171;
  background-color: #fff5f5;
}

/* 選択済みスタイル */
.choice-label.is-selected {
  border-color: #6366f1;
  background-color: #eef2ff;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
}
.choice-label.is-selected .choice-badge {
  background-color: #6366f1;
  color: #fff;
  border-color: #6366f1;
  font-size: 1rem;
  font-weight: 700;
  min-width: 2rem;
}
</style>

<script>
document.addEventListener('turbo:load', initChoiceCards);
document.addEventListener('DOMContentLoaded', initChoiceCards);
document.addEventListener('turbo:load', initSubmitGuard);
document.addEventListener('DOMContentLoaded', initSubmitGuard);

function countAnswered() {
  var total = document.querySelectorAll('[data-question]').length;
  var answered = 0;
  document.querySelectorAll('[data-question]').forEach(function(container) {
    if (container.querySelectorAll('.choice-label.is-selected').length > 0) answered++;
  });
  return { answered: answered, total: total };
}

function updateSubmitButton() {
  var btn      = document.getElementById('submit-btn');
  var progress = document.getElementById('submit-progress');
  var c = countAnswered();
  if (!btn) return;

  if (c.answered >= c.total) {
    btn.disabled = false;
    btn.style.opacity = '';
    btn.style.cursor  = '';
  } else {
    btn.disabled = true;
    btn.style.opacity = '0.35';
    btn.style.cursor  = 'not-allowed';
  }
  if (progress) progress.textContent = c.answered + ' / ' + c.total + ' 問回答済み';
}

function initSubmitGuard() {
  updateSubmitButton();
}

function initChoiceCards() {
  document.querySelectorAll('.choice-label').forEach(function(label) {
    label.addEventListener('click', function(e) {
      var radio = document.getElementById(this.getAttribute('for'));
      if (!radio) return;

      if (radio.checked) {
        // すでに選択済み → クリックで解除
        e.preventDefault();
        radio.checked = false;
        this.classList.remove('is-selected');
        var badge = this.querySelector('.choice-badge');
        if (badge) badge.textContent = '未選択';
        updateSubmitButton();
      }
      // 未選択の場合はブラウザ標準の radio 選択に任せる（change イベントで処理）
    });
  });

  document.querySelectorAll('.choice-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
      // この問題のコンテナ内だけをリセット（他の問題に影響させない）
      var questionContainer = this.closest('[data-question]');
      if (!questionContainer) return;

      questionContainer.querySelectorAll('.choice-radio').forEach(function(r) {
        var label = document.querySelector('label[for="' + r.id + '"]');
        if (label) {
          label.classList.remove('is-selected');
          var badge = label.querySelector('.choice-badge');
          if (badge) badge.textContent = '未選択';
        }
      });
      var selectedLabel = document.querySelector('label[for="' + this.id + '"]');
      if (selectedLabel) {
        selectedLabel.classList.add('is-selected');
        var badge = selectedLabel.querySelector('.choice-badge');
        if (badge) badge.textContent = selectedLabel.dataset.letter;
      }
      updateSubmitButton();
    });
  });
}
</script>
