# CI stub .env — ダミー値のみ。実際の秘密情報は含まない。
# docker compose config の構文検証専用。
GEMINI_API_KEY=ci-dummy-key
GROQ_API_KEY=ci-dummy-key
CEREBRAS_API_KEY=ci-dummy-key
MINIO_ROOT_USER=ci-minio-user
MINIO_ROOT_PASSWORD=ci-minio-password
POSTGRES_PASSWORD=ci-postgres-password
MINIGAME_DB_USER=ci-db-user
MINIGAME_DB_PASSWORD=ci-db-password
MINIGAME_DB_NAME=ci-minigame-db
MINIGAME_DATABASE_URL=postgresql://ci-db-user:ci-db-password@localhost:5432/ci-minigame-db
MINIGAME_REDIS_URL=redis://localhost:6379/0
TZ=Asia/Tokyo
OPENCLAW_PORT=18789
OPENCLAW_BROWSER_PORT=18791
LITELLM_MASTER_KEY=ci-litellm-key
PAPERLESS_SECRET_KEY=ci-paperless-secret
N8N_MCP_KEY=ci-n8n-mcp-key
